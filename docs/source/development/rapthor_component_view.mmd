flowchart LR
    classDef interface fill:#eaf3ff,stroke:#2b5c99,color:#1d2d3f
    classDef domain fill:#fff7cc,stroke:#9b7a00,color:#1d2d3f
    classDef adapter fill:#fff2df,stroke:#b96c00,color:#1d2d3f
    classDef execution fill:#e7f6ec,stroke:#2f855a,color:#1d2d3f
    classDef runtime fill:#eee8ff,stroke:#6b46c1,color:#1d2d3f
