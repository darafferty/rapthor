    subgraph user_surface["User interface and configuration"]
        cli["rapthor CLI"]
        parset["Parset, strategy, examples"]
    end

    subgraph domain["Domain model: rapthor.lib"]
        field["Field state"]
        observation["Observation and sectors"]
        strategy["Calibration and imaging strategy"]
        operation_base["Operation lifecycle"]
    end

    subgraph operations["Operation adapters: rapthor.operations"]
        op_concat["Concatenate operation"]
