    subgraph observability["Observability"]
        prefect_ui["Prefect dashboard"]
        dask_ui["Dask dashboard"]
        command_logs["commands.jsonl, logs, profiles, metrics"]
        artifacts["Prefect artifacts"]
    end

    products["Pipeline products and output records"]

