    user["User runs: rapthor input.parset"]
    bootstrap["runtime bootstrap"]
    pipeline_flow["pipeline_flow"]

    subgraph operation_flows["Operation-level Prefect flows"]
        concatenate_flow["concatenate_flow"]
        calibrate_flow["calibrate_flow"]
        predict_flow["predict_flow"]
        image_flow["image_flow"]
        mosaic_flow["mosaic_flow"]
    end

    subgraph tasks["Prefect tasks and task bodies"]
        concatenate_tasks["concatenate chunks"]
        calibration_tasks["draw model, solve chunks, collect/process h5parms"]
