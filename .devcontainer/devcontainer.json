{
  "name": "Rapthor Dev Container",
  "build": {
    "context": "..",
    "dockerfile": "../ci/ubuntu_24_04-base",
    "target": "dev",
    "options": [
      "--platform=linux/amd64"
    ]
  },
  "runArgs": [
    "--platform=linux/amd64",
    "--shm-size=4g"
  ],
  "workspaceFolder": "/app",
  "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind,consistency=cached",
  "postCreateCommand": "python3 -m pip install --upgrade pip && SETUPTOOLS_SCM_PRETEND_VERSION_FOR_RAPTHOR=0.0.0 python3 -m pip install -e . && SETUPTOOLS_SCM_PRETEND_VERSION_FOR_RAPTHOR=0.0.0 python3 -m pip install --group=dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "remoteEnv": {
    "PYTHONPATH": "/app:${PYTHONPATH}",
    "RAPTHOR_CONTAINER_WORKSPACE": "/app",
    "RAPTHOR_HOST_WORKSPACE": "${localWorkspaceFolder}"
  }
}
