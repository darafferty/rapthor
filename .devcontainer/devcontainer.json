{
  "name": "Rapthor Dev Container",
  "build": {
	"context": "..",
    "dockerfile": "Dockerfile",
    "target": "dev"
  },
  "runArgs": ["--shm-size=4g"],
  "workspaceFolder": "/app",
  "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind,consistency=cached",
  "postCreateCommand": "pip install --upgrade pip && pip install --no-binary=bdsf bdsf && pip install -e . && pip install --group=dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "remoteEnv": {
    "PYTHONPATH": "/app:${PYTHONPATH}"
  }
}
