# Template parset for integration tests
# 
# Missing values in this template are provided by a pytest fixture to generate
# a complete parset for integration testing. Parameters may be further updated 
# using the update_parset() helper function provided in test_rapthor.py.
# This facilitates running integration tests with different parset options.

[global]
dir_working = 
input_ms = 
data_colname = DATA
generate_initial_skymodel = False
generate_initial_skymodel_radius = None
generate_initial_skymodel_data_fraction = 0.2
download_initial_skymodel = False
download_initial_skymodel_radius = 5.0
download_initial_skymodel_server = TGSS
download_overwrite_skymodel = True
input_skymodel = 
apparent_skymodel = 
regroup_input_skymodel = True
strategy = 
selfcal_data_fraction = 0.2
input_h5parm = None
input_fulljones_h5parm = None
facet_layout = None
dde_mode = faceting

[calibration]
fast_freqstep_hz = 1e6
slow_freqstep_hz = 1e6
fast_smoothnessconstraint = 6.0e6
slow_smoothnessconstraint = 4.0e6
propagatesolutions = True
use_wsclean_predict = False
wsclean_predict_bw = 2e6
maxiter = 50
stepsize = 0.2
tolerance = 0.001

[imaging]
grid_width_ra_deg = 0.25
grid_width_dec_deg = 0.25
grid_center_ra = 1h37m41.299s
grid_center_dec = +33d09m35.132s
grid_nsectors_ra = 1
idg_mode = cpu
reweight = True
average_visibilities = False
bda_timebase = 0.0
bda_frequencybase = 0.0
save_image_cube = False
image_cube_stokes_list = [I]
make_quv_images = False
disable_iquv_clean = False
photometry_skymodel =
astrometry_skymodel =
shared_facet_rw = False
normalization_skymodels =
normalization_reference_frequencies =

  
[cluster]
batch_system = single_machine
max_nodes = 1
local_dask_workers = 1
cpus_per_task = 6
mem_per_node_gb = 0
max_cores = 6
max_threads = 6
deconvolution_threads = 3
parallel_gridding_tasks = 3
local_scratch_dir = 
global_scratch_dir = 
use_container = False
container_type = docker
debug_workflow = False
keep_temporary_files = False
allow_internet_access = 
prefect_task_runner = local_dask
prefect_command_profile = auto
prefect_publish_fits_previews = False
prefect_publish_postage_stamp_previews = False
prefect_postage_stamp_preview_count = 5
prefect_postage_stamp_preview_size_px = 96
prefect_fits_preview_clip_percentile = 99.9
